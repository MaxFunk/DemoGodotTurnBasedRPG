code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform bool ButtonActive = true;
uniform uint ButtonMode = 0;
uniform vec4 ButtonMode2 : source_color = vec4(0.850000, 0.450500, 0.483792, 1.000000);
uniform vec4 ButtonMode1 : source_color = vec4(0.408000, 0.673200, 0.850000, 1.000000);
uniform vec4 ButtonMode0 : source_color = vec4(0.850000, 0.790500, 0.790500, 1.000000);
uniform vec4 ButtonOff : source_color = vec4(0.300000, 0.300000, 0.300000, 1.000000);



void fragment() {
// BooleanParameter:2
	bool n_out2p0 = ButtonActive;


// UIntParameter:6
	uint n_out6p0 = ButtonMode;


// Compare:14
	uint n_in14p1 = 2u;
	bool n_out14p0 = n_out6p0 == n_in14p1;


// ColorParameter:10
	vec4 n_out10p0 = ButtonMode2;


// Compare:13
	uint n_in13p1 = 1u;
	bool n_out13p0 = n_out6p0 == n_in13p1;


// ColorParameter:9
	vec4 n_out9p0 = ButtonMode1;


// ColorParameter:8
	vec4 n_out8p0 = ButtonMode0;


	vec4 n_out11p0;
// Switch:11
	n_out11p0 = mix(n_out8p0, n_out9p0, float(n_out13p0));


	vec4 n_out12p0;
// Switch:12
	n_out12p0 = mix(n_out11p0, n_out10p0, float(n_out14p0));


// ColorParameter:3
	vec4 n_out3p0 = ButtonOff;


	vec4 n_out4p0;
// Switch:4
	n_out4p0 = mix(n_out3p0, n_out12p0, float(n_out2p0));


// Output:0
	ALBEDO = vec3(n_out4p0.xyz);


}
