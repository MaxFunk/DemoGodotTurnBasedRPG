code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec2 OffsetUV;
uniform sampler2D Minimap2D;



void fragment() {
// Input:4
	vec2 n_out4p0 = UV;


// VectorOp:5
	vec2 n_in5p1 = vec2(2.00000, 2.00000);
	vec2 n_out5p0 = n_out4p0 / n_in5p1;


// VectorOp:6
	vec2 n_in6p1 = vec2(0.25000, 0.25000);
	vec2 n_out6p0 = n_out5p0 + n_in6p1;


// Vector2Parameter:8
	vec2 n_out8p0 = OffsetUV;


// VectorOp:7
	vec2 n_out7p0 = n_out6p0 + n_out8p0;


	vec4 n_out2p0;
// Texture2D:2
	n_out2p0 = texture(Minimap2D, n_out7p0);


// Output:0
	COLOR.a = n_out2p0.x;


}
"
