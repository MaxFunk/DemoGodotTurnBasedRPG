// Mix:10
	vec3 n_out10p0 = mix(vec3(n_out3p0.xyz), vec3(n_out6p0.xyz), vec3(n_out12p0));


	vec3 n_out4p0;
// Switch:4
	vec3 n_in4p2 = vec3(0.00000, 0.00000, 0.00000);
	n_out4p0 = mix(n_in4p2, n_out10p0, float(n_out2p0));


// Output:0
	ALBEDO = vec3(n_out13p0.xyz);
	EMISSION = n_out4p0;


}
