code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_disabled, diffuse_lambert, specular_schlick_ggx, world_vertex_coords, shadows_disabled;


// Varyings
varying vec3 var_world_pos;




void vertex() {
// Input:3
	mat4 n_out3p0 = MODEL_MATRIX;


// Input:4
	vec3 n_out4p0 = VERTEX;


// TransformVectorMult:5
	vec3 n_out5p0 = (n_out3p0 * vec4(n_out4p0, 1.0)).xyz;


// VaryingSetter:2
	var_world_pos = n_out5p0;


}

void fragment() {
// ColorConstant:2
	vec4 n_out2p0 = vec4(0.180000, 0.480667, 1.000000, 1.000000);


// ColorConstant:13
	vec4 n_out13p0 = vec4(0.178200, 0.475860, 0.990000, 0.501961);


// VaryingGetter:10
	vec3 n_out10p0 = var_world_pos;


// VectorDecompose:7
	float n_out7p0 = n_out10p0.x;
	float n_out7p1 = n_out10p0.y;
	float n_out7p2 = n_out10p0.z;


// Input:5
	float n_out5p0 = TIME;


// FloatOp:9
	float n_in9p1 = 0.10000;
	float n_out9p0 = n_out5p0 * n_in9p1;


// FloatOp:8
	float n_out8p0 = n_out7p0 * n_out9p0;


// FloatFunc:4
	float n_out4p0 = sin(n_out8p0);


// FloatOp:11
	float n_in11p1 = 1.00000;
	float n_out11p0 = n_out4p0 + n_in11p1;


// FloatOp:12
	float n_in12p1 = 0.50000;
	float n_out12p0 = n_out11p0 * n_in12p1;


// Mix:6
	vec4 n_out6p0 = mix(n_out2p0, n_out13p0, n_out12p0);


// VectorDecompose:14
	float n_out14p0 = n_out6p0.x;
	float n_out14p1 = n_out6p0.y;
	float n_out14p2 = n_out6p0.z;
	float n_out14p3 = n_out6p0.w;


// VectorCompose:15
	vec3 n_out15p0 = vec3(n_out14p0, n_out14p1, n_out14p2);


// Output:0
	ALBEDO = n_out15p0;
	ALPHA = n_out14p3;


}
"
